generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  plan             String       @default("free")
  stripeCustomerId String?      @unique
  subscribedUntil  DateTime?
  createdAt        DateTime     @default(now())
  usageEvents      UsageEvent[]
}

model UsageEvent {
  id           String   @id @default(cuid())
  userId       String
  action       String
  provider     String   @default("anthropic")
  model        String?
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, action, createdAt])
}

model ThreadCategory {
  id           String   @id @default(cuid())
  userEmail    String
  threadId     String
  subject      String
  participants String[]
  snippet      String
  lastDate     String
  isRead       Boolean  @default(true)
  messageCount Int      @default(1)
  category     String
  tags         String[]
  oneLiner     String?
  updatedAt    DateTime @updatedAt

  @@unique([userEmail, threadId])
  @@index([userEmail])
}

model ResponseCache {
  id        String   @id @default(cuid())
  userEmail String
  prefix    String
  cacheKey  String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userEmail, prefix, cacheKey])
}

model Embedding {
  id        String   @id @default(cuid())
  userEmail String
  threadId  String
  vector    Float[]
  updatedAt DateTime @updatedAt

  @@unique([userEmail, threadId])
  @@index([userEmail])
}
